<!DOCTYPE html>
<html>
<head>
    <title>Fake Product Review Detection</title>
    <style>
        body {
            font-family: Arial;
            background-color: #f2f2f2;
            text-align: center;
            margin-top: 100px;
        }
        textarea {
            width: 400px;
            height: 120px;
        }
        button {
            padding: 10px 20px;
            font-size: 16px;
        }
        h2 {
            color: green;
        }
    </style>
</head>
<body>

    <h1>Fake Product Review Detection</h1>

    <form action="/predict" method="post">
        <textarea name="review" placeholder="Enter product review here..." required></textarea><br><br>
        <button type="submit">Check Review</button>
    </form>

    {% if prediction %}
        <h2>{{ prediction }}</h2>
    {% endif %}

</body>
</html>
